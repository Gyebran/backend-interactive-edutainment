{
    "compilerOptions":  {
                            "target":  "ES2020",
                            "module":  "commonjs",
                            "outDir":  "./dist",
                            "rootDir":  "./src",
                            "strict":  false,
                            "esModuleInterop":  true,
                            "baseUrl":  ".",
                            "moduleResolution":  "node",
                            "skipLibCheck":  true,
                            "noImplicitAny": false,
                            "paths":  {
                                          "@/*":  [
                                                      "./src/*"
                                                  ]
                                      }
                        },
    "include":  [
                    "src/**/*"
                ]
}
